{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "rootDir": "."
  },
  "include": ["src", "tests", "rslib.config.ts", "rstest.config.ts"]
}
