{
	"name": "kyss-js",
	"version": "1.0.2",
	"description": "Keep Your State Simple — proxy-tracked global state for React",
	"license": "MIT",
	"author": "lalexdotcom",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lalexdotcom/kyss-js.git"
	},
	"homepage": "https://github.com/lalexdotcom/kyss-js#readme",
	"bugs": {
		"url": "https://github.com/lalexdotcom/kyss-js/issues"
	},
	"keywords": [
		"state",
		"state-management",
		"react",
		"proxy",
		"store",
		"hooks",
		"typescript",
		"zustand",
		"valtio"
	],
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		},
		"./react": {
			"import": "./dist/react/index.js",
			"require": "./dist/react/index.cjs",
			"types": "./dist/react/index.d.ts"
		}
	},
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"test": "rstest run",
		"test:watch": "rstest"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"devDependencies": {
		"@microsoft/api-extractor": "^7.58.7",
		"@rslib/core": "^0.21.4",
		"@rstest/core": "^0.9.10",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"jsdom": "^29.1.1",
		"react": "^19.2.6",
		"typescript": "^6.0.3"
	},
	"packageManager": "npm@11.12.1"
}
